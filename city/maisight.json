{
  "repo": "maisight",
  "layers": ["back", "mid", "front", "under"],
  "components": [
    { "id": "tests", "name": "Test Yards", "layer": "under", "kind": "tests", "color": "#5c6b73",
      "globs": ["tests/*", "backend/tests/*", "frontend/tests/*"], "group": 3 },
    { "id": "infra", "name": "Infraworks", "layer": "under", "kind": "infra", "color": "#3a3f4a",
      "globs": ["infra/*", "scripts/*", ".github/*", "justfile", "pyproject.toml", "uv.lock",
                ".env.example", ".gitignore", "tmp/*"] },
    { "id": "storage", "name": "Storage Vaults", "layer": "back", "kind": "storage", "color": "#4a6b5c",
      "globs": ["backend/storage/*"] },
    { "id": "analytics", "name": "Analytics Exchange", "layer": "mid", "kind": "service", "color": "#8e5d9f",
      "globs": ["backend/analytics/*"] },
    { "id": "extract", "name": "Extraction Works", "layer": "mid", "kind": "service", "color": "#b5651d",
      "globs": ["backend/extract/*", "backend/parse/*", "backend/process/*", "backend/render/*"] },
    { "id": "sources", "name": "Sources Intake", "layer": "mid", "kind": "service", "color": "#2980b9",
      "globs": ["backend/sources/*", "backend/corpus/*"] },
    { "id": "api", "name": "API Row", "layer": "mid", "kind": "api", "color": "#d4a953",
      "globs": ["backend/*"] },
    { "id": "civic", "name": "Civic Plaza", "layer": "front", "kind": "civic", "color": "#d4a953",
      "globs": [] },
    { "id": "widget", "name": "Widget Arcade", "layer": "front", "kind": "frontend", "color": "#16a085",
      "globs": ["frontend/src/widget/*", "frontend/src/extension/*"] },
    { "id": "reading", "name": "Reading District", "layer": "front", "kind": "frontend", "color": "#5b8dd9",
      "globs": ["frontend/*", "landing/*"] },
    { "id": "docs", "name": "Docs Quarter", "layer": "front", "kind": "docs", "color": "#c9b78a",
      "globs": ["docs/*", "*.md"] }
  ],
  "clouds": [
    { "name": "Claude API", "tether": "extract" },
    { "name": "MinIO", "tether": "storage" },
    { "name": "Caddy", "tether": "api" },
    { "name": "GitHub Actions", "tether": "infra" }
  ]
}
